PANEL_SCHEME=https
PANEL_HOST=panel.example.com
PANEL_PORT=2053
PANEL_BASE_PATH=/randompath
PANEL_USERNAME=admin
PANEL_PASSWORD=change_me
PANEL_2FA=
PANEL_VERIFY_TLS=true

INBOUND_ID=1
API_TOKEN=change_me

VLESS_HOST=vpn.example.com
DEFAULT_FLOW=xtls-rprx-vision
DEFAULT_FINGERPRINT=random
DEFAULT_ALPN=
REQUEST_TIMEOUT=10

POSTGRES_DB=script_api
POSTGRES_USER=script_api
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://script_api:change_me@127.0.0.1:5432/script_api
ADMIN_USER=admin
ADMIN_PASS=change_me

# Optional: multiple 3x-ui servers (JSON list). If set, single PANEL_* is ignored.
# Example:
# PANEL_SERVERS_JSON=[{"id":"srv1","name":"Main","scheme":"https","host":"panel.example.com","port":2053,"base_path":"/random","username":"admin","password":"pass","verify_tls":true,"inbound_id":1,"vless_host":"vpn.example.com"}]
PANEL_SERVERS_JSON=
